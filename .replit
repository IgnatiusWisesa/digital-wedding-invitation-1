modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-sheet:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 22477
externalPort = 80

[userenv]

[userenv.shared]
NODE_ENV = "development"
JWT_EXPIRATION = "24h"
ADMIN_USERNAME = "admin"
GOOGLE_SHEETS_ID = "1Pn-Tcjq1albYU2lrxtLgJ6yzBDoXptMRlL_iUcKJfP0"

[nix]
channel = "stable-25_05"
